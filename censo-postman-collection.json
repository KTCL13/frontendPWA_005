              "raw": "{\n  \"nombres\": \"Juan Carlos\",\n  \"apellidos\": \"Perez García\",\n  \"tipoDocumento\": \"CC\",\n  \"documento\": \"1234567890\",\n  \"direccion\": \"Calle Principal 123\",\n  \"telefono\": \"3001234567\",\n  \"ciudad\": \"Bogotá\"\n}"

    {
      "name": "Censos",
      "item": [
        {
          "name": "Crear Censo (con JWT)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Base64 de prueba (1 KB), puedes reemplazar con una imagen real codificada en base64",
                  "const smallBase64 = 'data:image/jpeg;base64,'",
                  "pm.environment.set('test_base64_foto', smallBase64);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const jsonData = pm.response.json();",
                  "  pm.environment.set('censo_id', jsonData.id);",
                  "  pm.test('Censo creado', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "  pm.test('Retorna datos anidados', function () { ",
                  "    pm.expect(jsonData.mascota).to.exist;",
                  "    pm.expect(jsonData.dueno).to.exist;",
                  "  });",
                  "} else if (pm.response.code === 401) {",
                  "  pm.test('Verifica JWT válido', function () { pm.expect(pm.response.code).to.equal(401); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idMascota\": \"{{mascota_id}}\",\n  \"idDueno\": \"{{persona_id}}\",\n  \"fotografia\": \"{{test_base64_foto}}\",\n  \"lat\": 4.6097,\n  \"lon\": -74.0817,\n  \"idProyecto\": \"PWA_GRUPO_01\",\n  \"color\": \"#FF5733\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/censos",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "censos"]
            }
          }
        },
        {
          "name": "Crear Censo de Prueba Push (rápido)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 200/201', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const jsonData = pm.response.json();",
                  "pm.environment.set('censo_id', jsonData.id);",
                  "pm.test('Censo id guardado', function () { pm.expect(jsonData.id).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idMascota\": \"{{mascota_id}}\",\n  \"idDueno\": \"{{persona_id}}\",\n  \"fotografia\": \"{{test_base64_foto}}\",\n  \"lat\": 4.6101,\n  \"lon\": -74.0820,\n  \"idProyecto\": \"PUSH_TEST\",\n  \"color\": \"#00A86B\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/censos",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "censos"]
            }
          }
        },
        {
          "name": "Listar Censos (para Mapa)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 200', function () { pm.expect(pm.response.code).to.equal(200); });",
                  "pm.test('Retorna array de censos', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
                  "pm.test('Cada censo tiene estructura para mapa', function () { ",
                  "  const censos = pm.response.json();",
                  "  if (censos.length > 0) {",
                  "    const censo = censos[0];",
                  "    pm.expect(censo.lat).to.exist;",
                  "    pm.expect(censo.lon).to.exist;",
                  "    pm.expect(censo.color).to.exist;",
                  "    pm.expect(censo.mascota).to.exist;",
                  "    pm.expect(censo.dueno).to.exist;",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/censos",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "censos"]
            }
          }
        },
        {
          "name": "Obtener Censo por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 200', function () { pm.expect(pm.response.code).to.equal(200); });",
                  "pm.test('Retorna censo anidado', function () { ",
                  "  const censo = pm.response.json();",
                  "  pm.expect(censo.id).to.exist;",
                  "  pm.expect(censo.mascota).to.exist;",
                  "  pm.expect(censo.dueno).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/censos/{{censo_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "censos", "{{censo_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Push Notifications",
      "item": [
        {
          "name": "Obtener clave pública VAPID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 200', function () { pm.expect(pm.response.code).to.equal(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Trae publicKey', function () { pm.expect(json.publicKey).to.be.a('string').and.not.empty; });",
                  "pm.collectionVariables.set('vapid_public_key', json.publicKey);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/push/key",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "push", "key"]
            }
          }
        },
        {
          "name": "Suscribirse a Push (con JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 204 (No Content)', function () { pm.expect(pm.response.code).to.equal(204); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endpoint\": \"https://fcm.googleapis.com/fcm/send/test-endpoint-{{$timestamp}}\",\n  \"expirationTime\": null,\n  \"keys\": {\n    \"p256dh\": \"BCEllqKoW7pNRWKR3p2H1PJh+sRLfMqXVhD0+A7wA2Q0aRpC8KN0K7m4b5L8Y8q8qP8m8r2P9s3T4u5V6w7X8Y\",\n    \"auth\": \"YgL6R4qZ8t9U0V1W2X3Y4Z5A6B7C8D9E0F1G2H3I4\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/push/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "push", "subscriptions"]
            }
          }
        }
      ]
    }
  ]

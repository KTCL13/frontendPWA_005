        {
          "name": "Listar Personas",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 200', function () { pm.expect(pm.response.code).to.equal(200); });",
                  "pm.test('Respuesta es array', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
                  "pm.test('Sin campo contrasena', function () { ",
                  "  const personas = pm.response.json();",
                  "  if (personas.length > 0) {",
                  "    pm.expect(personas[0]).to.not.have.property('contrasena');",
                  "  }",
                  "});"
                ]
              }
            }

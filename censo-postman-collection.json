{
  "info": {
    "name": "Censo PWA API",
    "description": "Colección de endpoints para pruebas de API REST del sistema de censo de mascotas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const jsonData = pm.response.json();",
                  "  pm.environment.set('jwt_token', jsonData.token);",
                  "  pm.test('Status code is 200/201', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "  pm.test('Token existe', function () { pm.expect(jsonData.token).to.exist; });",
                  "  pm.test('Tipo token es Bearer', function () { pm.expect(jsonData.tipoToken).to.equal('Bearer'); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": \"admin\",\n  \"contrasena\": \"Admin123*\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
